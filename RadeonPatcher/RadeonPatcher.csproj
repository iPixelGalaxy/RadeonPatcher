<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishDir>$(MSBuildProjectDirectory)\..\</PublishDir>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <ApplicationIcon>Resources\AMDSoftwareConsumer.ico</ApplicationIcon>
    <AssemblyName>RadeonPatcher</AssemblyName>
    <Product>RadeonPatcher</Product>
    <Description>Independent Radeon driver installer and compatibility patcher.</Description>
    <Authors>RadeonPatcher contributors</Authors>
    <Copyright>Copyright © RadeonPatcher contributors</Copyright>
    <Version>1.0.0</Version>
    <UpdateCheckerPublishDir>$(BaseIntermediateOutputPath)update-checker\</UpdateCheckerPublishDir>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\Tools\**\*" LogicalName="Tools\%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="Resources\BundledAudio\**\*" LogicalName="BundledAudio\%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="Resources\GpuModels.json" LogicalName="GpuModels.json" />
    <EmbeddedResource Include="$(UpdateCheckerPublishDir)RadeonPatcherUpdateCheck.exe"
                      LogicalName="UpdateChecker\RadeonPatcherUpdateCheck.exe" />
  </ItemGroup>

  <Target Name="BuildUpdateChecker" BeforeTargets="PrepareResources">
    <MSBuild Projects="..\RadeonPatcher.UpdateCheck\RadeonPatcher.UpdateCheck.csproj"
             Targets="Restore"
             Properties="Configuration=$(Configuration);RuntimeIdentifier=win-x64" />
    <MSBuild Projects="..\RadeonPatcher.UpdateCheck\RadeonPatcher.UpdateCheck.csproj"
             Targets="Publish"
             Properties="Configuration=$(Configuration);RuntimeIdentifier=win-x64;SelfContained=true;PublishAot=false;PublishSingleFile=true;PublishTrimmed=false;UseAppHost=true;PublishDir=$(MSBuildProjectDirectory)\$(UpdateCheckerPublishDir)" />
  </Target>

  <ItemGroup>
    <Resource Include="Resources\AMDSoftwareConsumer.ico" />
  </ItemGroup>

  <Target Name="StopRunningAppBeforePublish" BeforeTargets="GenerateSingleFileBundle" Condition="'$(PublishSingleFile)' == 'true'">
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;$ErrorActionPreference = 'SilentlyContinue'; Get-Process -Name '$(AssemblyName)' -ErrorAction SilentlyContinue | ForEach-Object { try { $_.CloseMainWindow() | Out-Null; Start-Sleep -Milliseconds 300; if (-not $_.HasExited) { Stop-Process -Id $_.Id -Force -ErrorAction Stop } } catch {} }; exit 0&quot;" />
  </Target>

</Project>
