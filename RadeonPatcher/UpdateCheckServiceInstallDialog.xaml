<Window x:Class="RadeonPatcher.UpdateCheckServiceInstallDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RadeonPatcher" Width="440" SizeToContent="Height" MinHeight="230"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Icon="Resources/AMDSoftwareConsumer.ico" Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Install update check service" TextWrapping="Wrap"/>
        <TextBlock Grid.Row="1" Margin="0,14,0,18" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" LineHeight="20"
                   Text="Choose when RadeonPatcher should check for newer AMD drivers. The checker only shows notifications; it does not install drivers automatically."/>

        <StackPanel Grid.Row="2" Margin="0,0,0,22">
            <CheckBox x:Name="CheckOnBootBox" Margin="0,0,0,14" Content="Check on boot" IsChecked="True"/>
            <TextBlock Margin="0,0,0,6" Text="Check frequency"/>
            <ComboBox x:Name="FrequencyBox" Height="34"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="100" Height="34" Margin="0,0,10,0" Content="Cancel" IsCancel="True" Click="CancelButton_Click"/>
            <Button Width="100" Height="34" Content="Install" IsDefault="True" Style="{StaticResource AccentDialogButtonStyle}" Click="InstallButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
