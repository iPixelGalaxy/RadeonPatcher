<Window x:Class="RadeonPatcher.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About RadeonPatcher" Width="540" SizeToContent="Height" MinHeight="390"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Icon="Resources/AMDSoftwareConsumer.ico" Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock FontSize="22" FontWeight="SemiBold" Text="About RadeonPatcher" HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1" Margin="0,20,0,22" HorizontalAlignment="Center">
            <Ellipse Width="104" Height="104">
                <Ellipse.Fill>
                    <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill"/>
                </Ellipse.Fill>
            </Ellipse>
            <TextBlock Margin="0,12,0,0" FontSize="16" HorizontalAlignment="Center">
                <Run Text="Made by"/><Run Text=" "/><Run x:Name="UsernameRun" Text="iPixelGalaxy" Foreground="{DynamicResource LogoBrush}" FontWeight="SemiBold"/>
            </TextBlock>
        </StackPanel>

        <Border Grid.Row="2" Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18,16">
            <StackPanel>
                <TextBlock FontSize="17" FontWeight="SemiBold" Text="A note from the creator" Margin="0,0,0,10"/>
                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" LineHeight="21"
                           Text="This tool was made out of frustration for the challenges of installing AMD GPU Drivers on Windows Server, it was completely AI assisted but I have dedication to bug testing and refining this project to perfection. Feature suggestions are always welcome. Thank you for using the tool &lt;3"/>
            </StackPanel>
        </Border>

        <Button Grid.Row="3" Width="112" Height="34" Margin="0,20,0,0" HorizontalAlignment="Left" Click="GitHubButton_Click" Style="{StaticResource AccentDialogButtonStyle}">
            <StackPanel Orientation="Horizontal">
                <Viewbox Width="17" Height="17" Margin="0,0,7,0">
                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Data="M12,2 C6.48,2 2,6.58 2,12.22 C2,16.73 4.87,20.56 8.84,21.91 C9.34,22 9.52,21.69 9.52,21.42 C9.52,21.18 9.51,20.38 9.51,19.53 C6.73,20.15 6.14,18.32 6.14,18.32 C5.68,17.13 5.03,16.81 5.03,16.81 C4.12,16.18 5.1,16.2 5.1,16.2 C6.1,16.27 6.63,17.25 6.63,17.25 C7.52,18.82 8.97,18.37 9.54,18.11 C9.63,17.45 9.89,17 10.17,16.75 C7.95,16.49 5.62,15.61 5.62,11.69 C5.62,10.57 6.01,9.65 6.65,8.93 C6.55,8.67 6.2,7.62 6.75,6.21 C6.75,6.21 7.59,5.94 9.5,7.26 C10.3,7.03 11.15,6.91 12,6.91 C12.85,6.91 13.7,7.03 14.5,7.26 C16.41,5.94 17.25,6.21 17.25,6.21 C17.8,7.62 17.45,8.67 17.35,8.93 C17.99,9.65 18.38,10.57 18.38,11.69 C18.38,15.62 16.04,16.48 13.81,16.74 C14.17,17.06 14.49,17.69 14.49,18.66 C14.49,20.05 14.48,21.16 14.48,21.42 C14.48,21.69 14.66,22.01 15.17,21.91 C19.13,20.55 22,16.73 22,12.22 C22,6.58 17.52,2 12,2 Z"/>
                </Viewbox>
                <TextBlock Text="GitHub" VerticalAlignment="Center"/>
            </StackPanel>
        </Button>
        <Button Grid.Row="3" Width="100" Height="34" Margin="0,20,0,0" HorizontalAlignment="Right" Content="OK" IsDefault="True" IsCancel="True" Style="{StaticResource AccentDialogButtonStyle}"/>
    </Grid>
</Window>
