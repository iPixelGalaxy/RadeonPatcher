<Window x:Class="RadeonPatcher.AppUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RadeonPatcher Update" Width="520" MinHeight="275" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        Icon="Resources/AMDSoftwareConsumer.ico" Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="UpdateScrollBarPageButtonStyle" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UpdateScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="{DynamicResource ScrollThumbBrush}" CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UpdateScrollBarStyle" TargetType="ScrollBar">
            <Setter Property="Background" Value="{DynamicResource ScrollTrackBrush}"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource UpdateScrollBarPageButtonStyle}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource UpdateScrollBarThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource UpdateScrollBarPageButtonStyle}"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="24,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock FontSize="20" FontWeight="SemiBold" Text="RadeonPatcher update available"/>
        <StackPanel Grid.Row="1" Margin="0,18,0,18">
            <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="A newer verified GitHub release is available." Margin="0,0,0,14"/>
            <Border Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="8">
            <Grid>
                <Grid.Resources>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}"/>
                </Grid.Resources>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="12,10">
                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="Current version"/>
                    <TextBlock x:Name="CurrentVersionText" Margin="0,3,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="12,10">
                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="Available version"/>
                    <TextBlock x:Name="LatestVersionText" Margin="0,3,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource LogoBrush}"/>
                </StackPanel>
            </Grid>
            </Border>
            <StackPanel x:Name="ReleaseNotesPanel" Margin="0,16,0,0" Visibility="Collapsed">
                <TextBlock FontWeight="SemiBold" Text="What's changed" Margin="0,0,0,8"/>
                <Border Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="8" Padding="12,8,7.5,8">
                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar" BasedOn="{StaticResource UpdateScrollBarStyle}"/>
                        </ScrollViewer.Resources>
                        <TextBlock x:Name="ReleaseNotesText" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" LineHeight="20"/>
                    </ScrollViewer>
                </Border>
            </StackPanel>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="105" Height="34" Margin="0,0,10,0" Content="Maybe Later" IsCancel="True"/>
            <Button Width="105" Height="34" Content="Update" IsDefault="True" Style="{StaticResource AccentDialogButtonStyle}" Click="UpdateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
