<Window x:Class="RadeonPatcher.AppUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RadeonPatcher Update" Width="430" Height="230"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock FontSize="20" FontWeight="SemiBold" Text="RadeonPatcher update available"/>
        <StackPanel Grid.Row="1" Margin="0,18,0,18">
            <TextBlock Text="A newer verified GitHub release is available." Margin="0,0,0,12"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="Gray" Text="Current version"/>
                    <TextBlock x:Name="CurrentVersionText" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Foreground="Gray" Text="Available version"/>
                    <TextBlock x:Name="LatestVersionText" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="105" Height="34" Margin="0,0,10,0" Content="Maybe Later" IsCancel="True"/>
            <Button Width="105" Height="34" Content="Update" IsDefault="True" Click="UpdateButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
